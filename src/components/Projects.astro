---
import Card from '@components/ui/Card.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects', ({ data }) => !data.inProgress))
	.sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));
---

<section
	data-testid="projects"
	id="projects"
	class="mt-40 mb-10 flex flex-col items-center justify-center md:mb-0 md:mt-40">
	<h2 data-i18n="projects.title" class="font-monospace text-2xl text-orange lg:text-4xl">Projects</h2>
	<span class="mb-10 h-1 w-10 bg-orange"></span>
	<div class="mb-10 flex w-full flex-col flex-wrap items-stretch md:flex-row">
		{
			projects.map((project) => (
				<Card
					url={project.data.link}
					title={project.data.title}
					description={project.data.description}
					alt={project.data.img_alt}
					tags={project.data.tags}
					img_src={project.data.img_src}
					img_position={project.data.img_position}
					i18nTitle={`project.${project.slug}.title`}
					i18nDesc={`project.${project.slug}.description`}
				/>
			))
		}
	</div>
	<a
		href="https://github.com/rafael-a-monteiro-math"
		target="_blank"
		rel="noopener"
		class="flex flex-row text-black hover:text-orange dark:text-white dark:hover:text-orange"
		aria-label="link to repository"
	>
		<span data-i18n="projects.archive">View full private projects archive</span>
		<svg
			xmlns="http://www.w3.org/2000/svg"
			fill="none"
			viewBox="0 0 24 24"
			stroke-width="1.5"
			stroke="currentColor"
			class="ml-1 h-6 w-6"
		>
			<path
				stroke-linecap="round"
				stroke-linejoin="round"
				d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3"></path>
		</svg>
	</a>
</section>
